 class MyTask extends Thread {
    public MyTask(String name) { super(name); }

    public void run() {
        System.out.println(Thread.currentThread().getName() + " is running");
    }
}

public class ThreadSequence {
    public static void main(String[] args) throws InterruptedException {
        Thread t1 = new MyTask("Thread-1");
        Thread t2 = new MyTask("Thread-2");
        Thread t3 = new MyTask("Thread-3");

        t1.start();
        t1.join();   // wait till t1 completes

        t2.start();
        t2.join();   // wait till t2 completes

        t3.start();
        t3.join();   // wait till t3 completes
    }
}

import java.util.concurrent.*;

public class SequentialExecutor {
    public static void main(String[] args) throws Exception {
        ExecutorService executor = Executors.newSingleThreadExecutor();

        Future<?> f1 = executor.submit(() -> System.out.println("Task 1 done"));
        f1.get(); // Wait for task 1

        Future<?> f2 = executor.submit(() -> System.out.println("Task 2 done"));
        f2.get(); // Wait for task 2

        Future<?> f3 = executor.submit(() -> System.out.println("Task 3 done"));
        f3.get(); // Wait for task 3

        executor.shutdown();
    }
}

